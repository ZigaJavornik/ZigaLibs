    <Method Name="TimestructMillisecondToString" Id="{9e53ed01-a7b4-0c70-3f0d-c189651d2549}">
      <Declaration><![CDATA[(* Converts TIMESTRUCT.wMillisecond to STRING.*)
METHOD TimestructMillisecondToString : STRING
VAR_INPUT
	in	: Tc2_Utilities.TIMESTRUCT;
	fillWithZeros	: BOOL;	// If set to true, result will have 0 added when only a single digit is present
END_VAR
VAR
	result	: STRING;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[result := WORD_TO_STRING(in.wMilliseconds);

IF NOT fillWithZeros THEN
	TimestructMillisecondToString := result;
	RETURN;
END_IF

IF Tc2_Standard.LEN(STR := result) < 3 THEN
	// _10 => 010
	result := Tc2_Standard.CONCAT(STR1 := '0', STR2 := result);
ELSIF Tc2_Standard.LEN(STR := result) < 2 THEN
	// __5 => 005
	result := Tc2_Standard.CONCAT(STR1 := '00', STR2 := result);
END_IF

TimestructMillisecondToString := result;]]></ST>
      </Implementation>
    </Method>
