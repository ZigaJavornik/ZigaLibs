    <Method Name="TimestructToString" Id="{16c56c6e-c977-04ab-26b5-1266e14fd5ea}">
      <Declaration><![CDATA[(* Converts TIMESTRUCT to STRING.*)
METHOD TimestructToString : STRING
VAR_INPUT
	timeFormat			: E_TimeFormat;	// Time format to apply to the timestruct conversion
	timeOfDaySeperator	: STRING(1);	// Specifies how time of day is split
	dateSeperator		: STRING(1);	// Specifies how date is split
	fillWithZeros		: BOOL;	// If set to true: month, day hour, minute and second will have 0 added when only a single digit is present
	IncludeMilliseconds	: BOOL; // If set to true, milliseconds will also be displayed in the result, else they are ignored
	in					: Tc2_Utilities.TIMESTRUCT;
END_VAR

VAR
	result			: Tc2_System.T_MaxString;
	stringBuilder	: FB_StringBuilder;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE timeFormat OF
	E_TimeFormat.DDMMYY:
		result := stringBuilder.Reset()
			.AddString(THIS^.TimestructDayToString(in, fillWithZeros))
			.AddString(dateSeperator)
			.AddString(THIS^.TimestructMonthToString(in, fillWithZeros))
			.AddString(dateSeperator)
			.AddString(THIS^.TimestructYearToString(in))
			.Create();

	E_TimeFormat.HHMMSS:
		result := stringBuilder.Reset()
			.AddString(THIS^.TimestructHourToString(in, fillWithZeros))
			.AddString(timeOfDaySeperator)
			.AddString(THIS^.TimestructMinuteToString(in, fillWithZeros))
			.AddString(timeOfDaySeperator)
			.AddString(THIS^.TimestructSecondToString(in, fillWithZeros))
			.Create();
			
		IF IncludeMilliseconds THEN
			result := stringBuilder.AddString(timeOfDaySeperator)
				.AddString(THIS^.TimestructMillisecondToString(in, fillWithZeros))
				.Create();
		END_IF
			
	E_TimeFormat.MMDDYY:
		result := stringBuilder.Reset()
			.AddString(THIS^.TimestructMonthToString(in, fillWithZeros))
			.AddString(dateSeperator)
			.AddString(THIS^.TimestructDayToString(in, fillWithZeros))
			.AddString(dateSeperator)
			.AddString(THIS^.TimestructYearToString(in))
			.Create();

	E_TimeFormat.YYMMDD:	
		result := stringBuilder.Reset()
			.AddString(THIS^.TimestructMonthToString(in, fillWithZeros))
			.AddString(dateSeperator)
			.AddString(THIS^.TimestructDayToString(in, fillWithZeros))
			.AddString(dateSeperator)
			.AddString(THIS^.TimestructYearToString(in))
			.Create();
		
	E_TimeFormat.DDMMYY_HHMMSS:
		result := stringBuilder.Reset()
			.AddString(THIS^.TimestructDayToString(in, fillWithZeros))
			.AddString(dateSeperator)
			.AddString(THIS^.TimestructMonthToString(in, fillWithZeros))
			.AddString(dateSeperator)
			.AddString(THIS^.TimestructYearToString(in))
			.AddString('_')
			.AddString(THIS^.TimestructHourToString(in, fillWithZeros))
			.AddString(timeOfDaySeperator)
			.AddString(THIS^.TimestructMinuteToString(in, fillWithZeros))
			.AddString(timeOfDaySeperator)
			.AddString(THIS^.TimestructSecondToString(in, fillWithZeros))
			.Create();
			
			IF IncludeMilliseconds THEN
				result := stringBuilder.AddString(timeOfDaySeperator)
					.AddString(THIS^.TimestructMillisecondToString(in, fillWithZeros))
					.Create();
			END_IF

	E_TimeFormat.MMDDYY_HHMMSS:
		result := stringBuilder.Reset()
			.AddString(THIS^.TimestructMonthToString(in, fillWithZeros))
			.AddString(dateSeperator)
			.AddString(THIS^.TimestructDayToString(in, fillWithZeros))
			.AddString(dateSeperator)
			.AddString(THIS^.TimestructYearToString(in))
			.AddString('_')
			.AddString(THIS^.TimestructHourToString(in, fillWithZeros))
			.AddString(timeOfDaySeperator)
			.AddString(THIS^.TimestructMinuteToString(in, fillWithZeros))
			.AddString(timeOfDaySeperator)
			.AddString(THIS^.TimestructSecondToString(in, fillWithZeros))
			.Create();
			
			IF IncludeMilliseconds THEN
				result := stringBuilder.AddString(timeOfDaySeperator)
					.AddString(THIS^.TimestructMillisecondToString(in, fillWithZeros))
					.Create();
			END_IF

	E_TimeFormat.YYMMDD_HHMMSS:
		result := stringBuilder.Reset()
			.AddString(THIS^.TimestructYearToString(in))
			.AddString(dateSeperator)
			.AddString(THIS^.TimestructMonthToString(in, fillWithZeros))
			.AddString(dateSeperator)
			.AddString(THIS^.TimestructDayToString(in, fillWithZeros))
			.AddString('_')
			.AddString(THIS^.TimestructHourToString(in, fillWithZeros))
			.AddString(timeOfDaySeperator)
			.AddString(THIS^.TimestructMinuteToString(in, fillWithZeros))
			.AddString(timeOfDaySeperator)
			.AddString(THIS^.TimestructSecondToString(in, fillWithZeros))
			.Create();
			
			IF IncludeMilliseconds THEN
				result := stringBuilder.AddString(timeOfDaySeperator)
					.AddString(THIS^.TimestructMillisecondToString(in, fillWithZeros))
					.Create();
			END_IF				
END_CASE

TimestructToString := result;]]></ST>
      </Implementation>
    </Method>
    <Method Name="TimestructYearToString" Id="{890f374d-d2ae-0cda-1183-6f244b5f11e0}">
      <Declaration><![CDATA[(* Converts TIMESTRUCT.wYear to STRING.*)
METHOD TimestructYearToString : STRING
VAR_INPUT
	in	: Tc2_Utilities.TIMESTRUCT;
END_VAR
VAR
	result	: STRING;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[result := WORD_TO_STRING(in.wYear);
TimestructYearToString := result;
]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>