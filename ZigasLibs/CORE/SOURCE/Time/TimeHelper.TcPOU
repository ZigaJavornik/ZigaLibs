<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="TimeHelper" Id="{2c3cbf53-1ca9-0cad-3537-8b6b96b10a6d}" SpecialFunc="None">
    <Declaration><![CDATA[// A class containing helper methods with time
PROGRAM TimeHelper
VAR
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="TimestructDayToString" Id="{ef9bf769-7a71-0b01-19d0-3d11b021f66b}">
      <Declaration><![CDATA[(* Converts TIMESTRUCT.wDay to STRING.*)
METHOD TimestructDayToString : STRING
VAR_INPUT
	in	: Tc2_Utilities.TIMESTRUCT;
	fillWithZeros	: BOOL;	// If set to true, result will have 0 added when only a single digit is present
END_VAR
VAR
	result	: STRING;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[result := WORD_TO_STRING(in.wDay);

IF NOT fillWithZeros THEN
	TimestructDayToString := result;
	RETURN;
END_IF

IF Tc2_Standard.LEN(STR := result) < 2 THEN
	result := Tc2_Standard.CONCAT(STR1 := '0', STR2 := result);
END_IF

TimestructDayToString := result;]]></ST>
      </Implementation>
    </Method>
    <Method Name="TimestructHourToString" Id="{f4b49b55-554d-0347-319d-8c92dc5effc0}">
